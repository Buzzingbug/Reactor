<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auto Reacter | Dashboard</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="icon" href="https://autoreacter.com/favicon.ico" type="image/x-icon">
</head>
<body>
    <div class="sidebar">
        <div class="logo" style="margin-bottom: 2rem;">
            <span style="font-size: 1.5rem;">✨</span>
            Auto Reacter
        </div>

        <div class="sidebar-title">Your Servers</div>
        <div class="guild-list">
            <a href="/" class="guild-item <%= !selectedGuildId ? 'active' : '' %>">
                <div class="guild-icon">🌎</div>
                <span>All Servers</span>
            </a>
            <% guilds.forEach(guild => { %>
                <a href="/?guild=<%= guild.id %>" class="guild-item <%= selectedGuildId === guild.id ? 'active' : '' %>">
                    <div class="guild-icon">
                        <% if (guild.icon) { %>
                            <img src="<%= guild.icon %>" alt="<%= guild.name %>">
                        <% } else { %>
                            <%= guild.name.charAt(0) %>
                        <% } %>
                    </div>
                    <span><%= guild.name %></span>
                </a>
            <% }) %>
        </div>

        <div class="sidebar-footer">
            <p>Connected as Bot</p>
            <div style="display: flex; gap: 5px; align-items: center; margin-top: 5px;">
                <span class="dot dot-active"></span> Online
            </div>
        </div>
    </div>

    <div class="main-content">
        <header>
            <div style="display: flex; align-items: center; gap: 1rem;">
                <h1 style="font-size: 1.5rem; color: var(--text-main);">
                    <%= selectedGuildId ? (guilds.find(g => g.id === selectedGuildId)?.name || 'Server Dashboard') : 'Global Overview' %>
                </h1>
                <span class="badge"><%= configs.length %> Channels</span>
            </div>
            <div class="nav-links">
                <span class="badge" style="background: rgba(88, 101, 242, 0.4); border-color: rgba(88, 101, 242, 0.4);">v1.0.0</span>
            </div>
        </header>
        
        <div class="channel-grid">
            <% configs.forEach((config, index) => { %>
                <div class="channel-card" id="card-<%= config.channel_id %>">
                    <div class="channel-card-header">
                        <div class="channel-info">
                            <h3>
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted);"><path d="M4 9h16M4 15h16M10 3L8 21M16 3l-2 18"/></svg>
                                <%= config.channelName %>
                            </h3>
                            <div class="guild-name"><%= config.guildName %></div>
                        </div>
                        <label class="switch">
                            <input type="checkbox" <%= config.enabled ? 'checked' : '' %> onchange="toggleChannel('<%= config.channel_id %>', this.checked)">
                            <span class="slider"></span>
                        </label>
                    </div>

                    <div class="emoji-settings">
                        <div class="emoji-item">
                            <span class="emoji-label">Media Reactions</span>
                            <div class="emoji-display">
                                <% if (config.media_emojis) { %>
                                    <% config.media_emojis.split(/[\s,]+/).forEach(emoji => { %>
                                        <span class="badge"><%= emoji %></span>
                                    <% }) %>
                                <% } else { %>
                                    <span class="no-emojis">No reactions set</span>
                                <% } %>
                            </div>
                        </div>

                        <div class="emoji-item">
                            <span class="emoji-label">Link Reactions</span>
                            <div class="emoji-display">
                                <% if (config.link_emojis) { %>
                                    <% config.link_emojis.split(/[\s,]+/).forEach(emoji => { %>
                                        <span class="badge"><%= emoji %></span>
                                    <% }) %>
                                <% } else { %>
                                    <span class="no-emojis">No reactions set</span>
                                <% } %>
                            </div>
                        </div>

                        <div class="emoji-item">
                            <span class="emoji-label">Text Reactions</span>
                            <div class="emoji-display">
                                <% if (config.text_emojis) { %>
                                    <% config.text_emojis.split(/[\s,]+/).forEach(emoji => { %>
                                        <span class="badge"><%= emoji %></span>
                                    <% }) %>
                                <% } else { %>
                                    <span class="no-emojis">No reactions set</span>
                                <% } %>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer">
                        <div class="role-badge">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: #6366f1;"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                            <%= config.role_id ? 'Restricted' : 'All Roles' %>
                        </div>
                        <div class="<%= config.enabled ? 'status-active' : 'status-inactive' %>">
                            <span class="dot <%= config.enabled ? 'dot-active' : 'dot-inactive' %>"></span>
                            <%= config.enabled ? 'Active' : 'Disabled' %>
                        </div>
                    </div>
                </div>
            <% }) %>

            <% if (configs.length === 0) { %>
                <div style="grid-column: 1 / -1; text-align: center; padding: 4rem; background: var(--glass); border-radius: 20px; border: 1px dashed rgba(255, 255, 255, 0.2);">
                    <div style="font-size: 3rem; margin-bottom: 1rem;">🔍</div>
                    <h3>No channels configured here.</h3>
                    <p style="color: var(--text-muted); margin-top: 0.5rem;">Use <code>/setup-reactions</code> in <%= selectedGuildId ? 'this server' : 'any server' %> to get started!</p>
                </div>
            <% } %>
        </div>
    </div>

    <script>
        async function toggleChannel(channelId, enabled) {
            try {
                const response = await fetch('/api/toggle', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ channel_id: channelId, enabled: enabled })
                });
                
                if (response.ok) {
                    const statusText = document.querySelector(`#card-${channelId} .status-active, #card-${channelId} .status-inactive`);
                    const dot = document.querySelector(`#card-${channelId} .dot`);
                    
                    if (enabled) {
                        statusText.className = 'status-active';
                        statusText.innerHTML = '<span class="dot dot-active"></span> Active';
                    } else {
                        statusText.className = 'status-inactive';
                        statusText.innerHTML = '<span class="dot dot-inactive"></span> Disabled';
                    }
                }
            } catch (err) {
                console.error('Failed to toggle channel status:', err);
                alert('Network error - could not update status.');
            }
        }
    </script>
</body>
</html>
